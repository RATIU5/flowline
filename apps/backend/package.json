{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "typecheck": "tsgo --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:effect",
    "@flowline/config": "workspace:*",
    "@flowline/db": "workspace:*",
    "@flowline/rpc": "workspace:*",
    "better-auth": "^1.5.6",
    "effect": "catalog:effect",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:effect",
    "@effect/vitest": "catalog:effect",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "catalog:typescript",
    "vitest": "catalog:testing"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
