{
  "name": "frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "typecheck": "svelte-kit sync && tsgo --noEmit --project tsconfig.json",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@effect/platform-browser": "catalog:effect",
    "@flowline/auth": "workspace:*",
    "@flowline/config": "workspace:*",
    "@flowline/rpc": "workspace:*",
    "effect": "catalog:effect",
    "sveltekit-effect-runtime": "catalog:svelte",
    "tailwindcss-corner-shape": "catalog:tailwindcss"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "catalog:svelte",
    "@sveltejs/kit": "catalog:svelte",
    "@sveltejs/vite-plugin-svelte": "catalog:svelte",
    "@tailwindcss/typography": "catalog:tailwindcss",
    "@tailwindcss/vite": "catalog:tailwindcss",
    "@typescript/native-preview": "catalog:typescript",
    "svelte": "catalog:svelte",
    "svelte-check": "catalog:svelte",
    "tailwindcss": "catalog:tailwindcss",
    "vite": "catalog:"
  }
}
