{
  "name": "flowline-root",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": {
    "packages": [
      "packages/**/*",
      "apps/**/*"
    ],
    "catalog": {
      "typescript": "^5.9.3",
      "vite": "8.0.0"
    },
    "catalogs": {
      "testing": {
        "vitest": "^4.1.0"
      },
      "tailwindcss": {
        "@tailwindcss/typography": "0.5.19",
        "@tailwindcss/vite": "4.2.1",
        "tailwindcss": "4.2.1",
        "tailwindcss-corner-shape": "1.4.6"
      },
      "svelte": {
        "@sveltejs/adapter-auto": "7.0.1",
        "@sveltejs/kit": "2.55.0",
        "@sveltejs/vite-plugin-svelte": "7.0.0",
        "svelte": "5.54.0",
        "svelte-check": "4.4.5"
      },
      "effect": {
        "effect": "4.0.0-beta.34",
        "@effect/platform-bun": "4.0.0-beta.34",
        "@effect/platform-browser": "4.0.0-beta.34",
        "@effect/language-service": "^0.80.0",
        "@effect/sql-pg": "4.0.0-beta.34",
        "@effect/opentelemetry": "4.0.0-beta.34",
        "@effect/vitest": "4.0.0-beta.34"
      }
    }
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev:fe": "bun run --elide-lines 0 --filter frontend dev",
    "dev:be": "bun run --elide-lines 0 --filter backend dev",
    "format:check": "biome format --verbose",
    "format:write": "biome format --write",
    "lint:check": "biome lint",
    "lint:write": "biome lint --write",
    "typecheck": "bun run --elide-lines 0 --filter '*' typecheck",
    "test": "bun run --workspaces test",
    "clean:all": "bun run clean:dist && bun run clean:packages",
    "clean:dist": "rimraf packages/**/dist",
    "clean:packages": "rimraf node_modules apps/**/node_modules packages/**/node_modules bun.lock && echo 'Re-install required'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@effect/language-service": "catalog:effect",
    "vitest": "catalog:testing",
    "@types/bun": "latest",
    "rimraf": "^6.1.3",
    "typescript": "catalog:"
  }
}
