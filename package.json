{
  "name": "flowline-root",
  "private": true,
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/**/*",
      "apps/**/*"
    ],
    "catalog": {
      "vite": "8.1.0"
    },
    "catalogs": {
      "lint": {
        "@biomejs/biome": "2.5.1",
        "oxfmt": "0.56.0",
        "oxlint": "1.71.0",
        "oxlint-tsgolint": "0.23.0"
      },
      "typescript": {
        "@effect/tsgo": "0.15.0",
        "typescript": "7.0.1-rc",
        "@typescript/native-preview": "7.0.0-dev.20260629.1"
      },
      "auth": {
        "better-auth": "^1.6.22"
      },
      "db": {
        "kysely": "0.29.2",
        "kysely-codegen": "0.20.0",
        "kysely-ctl": "0.21.0"
      },
      "testing": {
        "vitest": "^4.1.9"
      },
      "tailwindcss": {
        "@tailwindcss/typography": "0.5.20",
        "@tailwindcss/vite": "4.3.2",
        "tailwindcss": "4.3.2"
      },
      "svelte": {
        "@sveltejs/adapter-auto": "7.0.1",
        "@sveltejs/kit": "2.68.0",
        "@sveltejs/vite-plugin-svelte": "7.1.2",
        "svelte": "5.56.4",
        "svelte-check": "4.4.5",
        "sveltekit-effect-runtime": "1.3.0"
      },
      "effect": {
        "effect": "4.0.0-beta.92",
        "@effect/platform-bun": "4.0.0-beta.92",
        "@effect/platform-browser": "4.0.0-beta.92",
        "@effect/language-service": "^0.86.2",
        "@effect/sql-pg": "4.0.0-beta.92",
        "@effect/opentelemetry": "4.0.0-beta.92",
        "@effect/vitest": "4.0.0-beta.92"
      }
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "effect-tsgo patch",
    "dev:fe": "bun run --elide-lines 0 --filter frontend dev",
    "dev:be": "bun run --elide-lines 0 --filter backend dev",
    "db:up": "set -a && source apps/backend/.env && set +a && podman run -d --name postgres -e POSTGRES_USER=${DB_USER} -e POSTGRES_PASSWORD=${DB_PASSWORD} -e POSTGRES_DB=${DB_NAME} -p 5432:5432 -v pgdata:/var/lib/postgresql/data postgres:16-alpine",
    "db:down": "podman stop postgres && podman rm postgres",
    "db:logs": "podman logs -f postgres",
    "db:migrate": "bun run --elide-lines 0 --filter @flowline/db migrate",
    "db:seed": "bun run --elide-lines 0 --filter @flowline/db seed",
    "db:codegen": "bun run --elide-lines 0 --filter @flowline/db codegen",
    "fmt:check": "oxfmt --check && biome format --verbose",
    "fmt": "oxfmt --write && biome format --write",
    "lint:check": "oxlint",
    "lint": "oxlint --fix",
    "typecheck": "bun run --elide-lines 0 --filter '*' typecheck",
    "test": "bun run --workspaces test",
    "clean:all": "bun run clean:dist && bun run clean:packages",
    "clean:dist": "rimraf packages/**/dist",
    "clean:packages": "rimraf node_modules apps/**/node_modules packages/**/node_modules bun.lock && echo 'Re-install required'"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:lint",
    "@effect/language-service": "catalog:effect",
    "@effect/tsgo": "catalog:typescript",
    "@types/bun": "latest",
    "@typescript/native-preview": "catalog:typescript",
    "oxfmt": "catalog:lint",
    "oxlint": "catalog:lint",
    "oxlint-tsgolint": "catalog:lint",
    "rimraf": "^6.1.3",
    "vitest": "catalog:testing"
  },
  "packageManager": "bun@1.3.10"
}
