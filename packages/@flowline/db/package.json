{
  "name": "@flowline/db",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/modules/client/index.ts",
    "./pool": "./src/modules/pool/index.ts",
    "./types": "./src/types/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "typecheck": "tsgo --noEmit --project tsconfig.json",
    "codegen": "set -a && source ../../../apps/backend/.env && set +a && kysely-codegen --dialect postgres --out-file src/types/db.ts --camel-case --url=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}",
    "migrate": "set -a && source ../../../apps/backend/.env && set +a && kysely migrate",
    "seed": "set -a && source ../../../apps/backend/.env && set +a && kysely seed"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:effect",
    "@flowline/config": "workspace:*",
    "effect": "catalog:effect",
    "kysely": "catalog:db",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:effect",
    "@effect/vitest": "catalog:effect",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "catalog:typescript",
    "kysely-codegen": "catalog:db",
    "kysely-ctl": "catalog:db",
    "vitest": "catalog:testing"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
